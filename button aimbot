local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local aimbotEnabled = false
local currentTarget = nil
local maxLockDistance = 35
local SMOOTHNESS = 0.85

local function GetRole()
    if not LocalPlayer.Team then return "Lobby" end
    local name = LocalPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" then return "Survivor" end
    return "Lobby"
end

local function lockMouse()
    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    UserInputService.MouseIconEnabled = false
end

local function unlockMouse()
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    UserInputService.MouseIconEnabled = true
end

local function getClosestTarget()
    local closest = nil
    local shortestDist = math.huge
    local center = Camera.ViewportSize / 2
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local char = p.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if root and hum and hum.Health > 0 then
                    local dist3D = (myRoot.Position - root.Position).Magnitude
                    if dist3D <= maxLockDistance then
                        local screenPoint, onScreen = Camera:WorldToViewportPoint(root.Position)
                        if onScreen then
                            local screenDist = (Vector2.new(screenPoint.X, screenPoint.Y) - center).Magnitude
                            if screenDist < shortestDist then
                                closest = p
                                shortestDist = screenDist
                            end
                        end
                    end
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if not aimbotEnabled then return end
    if GetRole() ~= "Killer" then
        if aimbotEnabled then
            aimbotEnabled = false
            unlockMouse()
            currentTarget = nil
            if button then
                button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                button.BackgroundTransparency = 0.15
                if stroke then stroke.Color = Color3.fromRGB(255, 100, 100) end
            end
        end
        return
    end
    
    if not currentTarget then
        currentTarget = getClosestTarget()
    end
    
    if currentTarget and currentTarget.Character then
        local root = currentTarget.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local lookAt = CFrame.new(Camera.CFrame.Position, root.Position)
            Camera.CFrame = Camera.CFrame:Lerp(lookAt, SMOOTHNESS)
        else
            currentTarget = nil
        end
    else
        currentTarget = nil
    end
end)

local button = nil
local stroke = nil
local ScreenGui = nil

if not game.CoreGui:FindFirstChild("SimpleAimbot") then
    ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SimpleAimbot"
    ScreenGui.Parent = game.CoreGui

    button = Instance.new("ImageButton")
    button.Size = UDim2.new(0, 50, 0, 50)
    button.Position = UDim2.new(1, -210, 1, -420)
    button.AnchorPoint = Vector2.new(1, 1)
    button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    button.BackgroundTransparency = 0.15
    button.Image = "rbxassetid://3926305904"
    button.ImageColor3 = Color3.fromRGB(255, 255, 255)
    button.ImageTransparency = 0.2
    button.Parent = ScreenGui
    button.Draggable = false

    local corner = Instance.new("UICorner", button)
    corner.CornerRadius = UDim.new(1, 0)
    
    stroke = Instance.new("UIStroke", button)
    stroke.Color = Color3.fromRGB(255, 100, 100)
    stroke.Thickness = 2
    stroke.Transparency = 0.5

    local dragging = false
    local dragStart = nil
    local startPos = nil

    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = button.Position
        end
    end)

    button.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    button.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            button.Position = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)

    button.MouseButton1Click:Connect(function()
        if not dragging then
            if GetRole() == "Killer" then
                aimbotEnabled = not aimbotEnabled
                
                if aimbotEnabled then
                    button.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
                    button.BackgroundTransparency = 0.3
                    stroke.Color = Color3.fromRGB(100, 255, 100)
                    lockMouse()
                else
                    button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                    button.BackgroundTransparency = 0.15
                    stroke.Color = Color3.fromRGB(255, 100, 100)
                    unlockMouse()
                    currentTarget = nil
                end
            else
                button.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                task.wait(0.1)
                button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            end
        end
        dragging = false
    end)
else
    ScreenGui = game.CoreGui.SimpleAimbot
    button = ScreenGui:FindFirstChildWhichIsA("ImageButton")
    stroke = button and button:FindFirstChildWhichIsA("UIStroke")
end

LocalPlayer:GetPropertyChangedSignal("Team"):Connect(function()
    if ScreenGui then
        if GetRole() == "Killer" then
            ScreenGui.Enabled = true
        else
            ScreenGui.Enabled = false
            if aimbotEnabled then
                aimbotEnabled = false
                if button then
                    button.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                    button.BackgroundTransparency = 0.15
                    if stroke then stroke.Color = Color3.fromRGB(255, 100, 100) end
                end
                unlockMouse()
                currentTarget = nil
            end
        end
    end
end)

if GetRole() == "Killer" then
    ScreenGui.Enabled = true
else
    ScreenGui.Enabled = false
end

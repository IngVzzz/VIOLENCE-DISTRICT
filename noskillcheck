local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local destroyedRemotes = {
    Healing = false,
    Generator = false
}

local activeConnections = {}

local function waitForInstance(parent, name, timeout)
    timeout = timeout or 3
    local start = tick()
    while not parent:FindFirstChild(name) and tick() - start < timeout do
        task.wait(0.1)
    end
    return parent:FindFirstChild(name)
end

local function DisableSkillCheckEvent(folderName)
    local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not Remotes then return false end

    local targetFolder = Remotes:FindFirstChild(folderName)
    if not targetFolder then return false end

    local SkillCheckEvent = targetFolder:FindFirstChild("SkillCheckEvent")
    if SkillCheckEvent then
        SkillCheckEvent:Destroy()
    end

    destroyedRemotes[folderName] = true
    return true
end

local function DestroyBoth()
    destroyedRemotes.Healing = false
    destroyedRemotes.Generator = false
    DisableSkillCheckEvent("Healing")
    DisableSkillCheckEvent("Generator")
end

local function WatchFolder(folderName)
    local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if not Remotes then return end

    local targetFolder = waitForInstance(Remotes, folderName, 2)
    if not targetFolder then return end

    local existing = targetFolder:FindFirstChild("SkillCheckEvent")
    if existing then 
        existing:Destroy() 
    end

    local conn = targetFolder.ChildAdded:Connect(function(child)
        if child.Name == "SkillCheckEvent" then
            child:Destroy()
            destroyedRemotes[folderName] = true
        end
    end)
    
    table.insert(activeConnections, conn)

    local ancestryConn
    ancestryConn = targetFolder.AncestryChanged:Connect(function()
        if not targetFolder.Parent then
            conn:Disconnect()
            if ancestryConn then ancestryConn:Disconnect() end
            for i, v in ipairs(activeConnections) do
                if v == conn or v == ancestryConn then
                    table.remove(activeConnections, i)
                    break
                end
            end
        end
    end)
    table.insert(activeConnections, ancestryConn)
end

local function WatchRemotesFolder()
    local function AddWatcher(folderName)
        local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if Remotes then
            local target = waitForInstance(Remotes, folderName, 1.5)
            if target then
                WatchFolder(folderName)
            end
        end
    end

    AddWatcher("Healing")
    AddWatcher("Generator")

    local remotesConn = ReplicatedStorage.ChildAdded:Connect(function(child)
        if child.Name == "Remotes" then
            task.wait(0.2)
            AddWatcher("Healing")
            AddWatcher("Generator")
        end
    end)
    table.insert(activeConnections, remotesConn)

    local remotes = ReplicatedStorage:FindFirstChild("Remotes")
    if remotes then
        local childAddedConn = remotes.ChildAdded:Connect(function(child)
            if child.Name == "Healing" or child.Name == "Generator" then
                task.wait(0.2)
                WatchFolder(child.Name)
                DisableSkillCheckEvent(child.Name)
            end
        end)
        table.insert(activeConnections, childAddedConn)
    end
end

local function SafeDestroyOnRespawn()
    local success, err = pcall(function()
        local Remotes = waitForInstance(ReplicatedStorage, "Remotes", 2)
        if Remotes then
            DestroyBoth()
            WatchRemotesFolder()
        end
    end)
    if not success then
        task.wait(0.5)
        SafeDestroyOnRespawn()
    end
end

local charConn
charConn = LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.3)
    SafeDestroyOnRespawn()
end)
table.insert(activeConnections, charConn)

SafeDestroyOnRespawn()

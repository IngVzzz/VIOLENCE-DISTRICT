local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer

local Hook = {
    Players = {
        ["Killer"] = {Color = Color3.fromRGB(255, 0, 0), On = true},
        ["Survivor"] = {Color = Color3.fromRGB(20, 171, 217), On = true}
    }
}

local isActive = false
local activeConnections = {}
local playerConnections = {}
local highlightCache = {}

-- Deteksi mobile buat throttle lebih agresif
local isMobile = RunService:IsMobile()
local RETRY_DELAY = if isMobile then 0.5 else 0.3
local MAX_RETRY = if isMobile then 3 else 2

local function safeDisconnect(conn)
    if conn and conn.Disconnect then
        pcall(conn.Disconnect, conn)
    end
end

local function clearAllConnections()
    for i = #activeConnections, 1, -1 do
        safeDisconnect(activeConnections[i])
        activeConnections[i] = nil
    end
    activeConnections = {}
    
    for player, conn in pairs(playerConnections) do
        safeDisconnect(conn)
        playerConnections[player] = nil
    end
end

local function GetLocalRole()
    local team = localPlayer.Team
    if not team then return "Lobby" end
    local name = team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" then return "Survivor" end
    return "Lobby"
end

local function RemoveHighlight(char)
    if not char then return end
    local h = char:FindFirstChild("ESP_Highlight")
    if h then
        h:Destroy()
    end
    highlightCache[char] = nil
end

local function ApplyHighlight(char, color)
    if not char or not color then return end
    
    -- Cek karakternya beneran udah kepasang
    if not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then
        return
    end
    
    if highlightCache[char] == color then return end
    
    local existing = char:FindFirstChild("ESP_Highlight")
    if existing and existing.FillColor == color then
        highlightCache[char] = color
        return
    end
    
    if existing then
        existing:Destroy()
    end
    
    -- Setting ringan buat mobile
    local h = Instance.new("Highlight")
    h.Name = "ESP_Highlight"
    h.FillColor = color
    h.OutlineColor = color
    h.FillTransparency = if isMobile then 0.85 else 0.8
    h.OutlineTransparency = if isMobile then 0.3 else 0.3
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent = char
    
    highlightCache[char] = color
end

local pendingUpdates = {}

local function UpdateSinglePlayerWithRetry(player, retryCount)
    if not isActive then return end
    if player == localPlayer then return end
    
    local char = player.Character
    local team = player.Team
    
    if not char or not team then
        -- Kalo karakter belum ada, coba lagi nanti
        if retryCount and retryCount < MAX_RETRY then
            task.delay(RETRY_DELAY, function()
                if isActive then
                    UpdateSinglePlayerWithRetry(player, (retryCount or 0) + 1)
                end
            end)
        end
        return
    end
    
    -- Tunggu karakter beneran stabil (buat mobile)
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then
        if retryCount and retryCount < MAX_RETRY then
            task.delay(RETRY_DELAY, function()
                if isActive then
                    UpdateSinglePlayerWithRetry(player, (retryCount or 0) + 1)
                end
            end)
        end
        return
    end
    
    local teamName = team.Name
    local color = nil
    
    if teamName == "Killer" and Hook.Players["Killer"].On then
        color = Hook.Players["Killer"].Color
    elseif teamName == "Survivors" and Hook.Players["Survivor"].On then
        color = Hook.Players["Survivor"].Color
    end
    
    if color then
        ApplyHighlight(char, color)
    else
        RemoveHighlight(char)
    end
end

local function UpdateSinglePlayer(player)
    UpdateSinglePlayerWithRetry(player, 0)
end

local function UpdateAllHighlights()
    if not isActive then return end
    local playersList = Players:GetPlayers()
    for i = 1, #playersList do
        local p = playersList[i]
        if p ~= localPlayer then
            UpdateSinglePlayerWithRetry(p, 0)
        end
    end
end

local function DisableESP()
    if not isActive then return end
    isActive = false
    local playersList = Players:GetPlayers()
    for i = 1, #playersList do
        local p = playersList[i]
        local char = p.Character
        if char then
            RemoveHighlight(char)
        end
    end
    highlightCache = {}
end

local function EnableESP()
    if isActive then return end
    isActive = true
    UpdateAllHighlights()
end

local lastTeamCheck = 0
local TEAM_COOLDOWN = if isMobile then 0.3 else 0.2

local function CheckAndToggle()
    local now = os.clock()
    if now - lastTeamCheck < TEAM_COOLDOWN then return end
    lastTeamCheck = now
    
    local role = GetLocalRole()
    if role == "Killer" or role == "Survivor" then
        if not isActive then
            EnableESP()
        else
            -- Refresh ESP kalo udah aktif (cegah hilang)
            UpdateAllHighlights()
        end
    else
        if isActive then DisableESP() end
    end
end

local pendingPlayerUpdates = {}

local function DebouncedUpdatePlayer(player)
    if pendingPlayerUpdates[player] then return end
    pendingPlayerUpdates[player] = true
    task.delay(if isMobile then 0.2 else 0.1, function()
        pendingPlayerUpdates[player] = nil
        if isActive then
            UpdateSinglePlayerWithRetry(player, 0)
        end
    end)
end

local function BindPlayerEvents(player)
    if player == localPlayer then return end
    
    if playerConnections[player] then
        safeDisconnect(playerConnections[player])
        playerConnections[player] = nil
    end
    
    local conn = player.CharacterAdded:Connect(function(char)
        -- Tunggu karakter beneran stabil di mobile
        if isMobile then
            task.wait(0.5)
        end
        DebouncedUpdatePlayer(player)
    end)
    playerConnections[player] = conn
    activeConnections[#activeConnections + 1] = conn
    
    -- Juga pantau team change player lain (kadang team bisa berubah setelah masuk)
    local teamConn
    teamConn = player:GetPropertyChangedSignal("Team"):Connect(function()
        DebouncedUpdatePlayer(player)
    end)
    playerConnections[player .. "_team"] = teamConn
    activeConnections[#activeConnections + 1] = teamConn
end

local function setupConnections()
    clearAllConnections()
    
    local teamConn = localPlayer:GetPropertyChangedSignal("Team"):Connect(CheckAndToggle)
    activeConnections[#activeConnections + 1] = teamConn
    
    local charConn = localPlayer.CharacterAdded:Connect(function()
        if isMobile then
            task.wait(0.8)
        else
            task.wait(0.3)
        end
        CheckAndToggle()
    end)
    activeConnections[#activeConnections + 1] = charConn
    
    local playerAddedConn = Players.PlayerAdded:Connect(BindPlayerEvents)
    activeConnections[#activeConnections + 1] = playerAddedConn
    
    local playerRemovingConn = Players.PlayerRemoving:Connect(function(player)
        local char = player.Character
        if char then
            RemoveHighlight(char)
        end
        if playerConnections[player] then
            safeDisconnect(playerConnections[player])
            playerConnections[player] = nil
        end
        if playerConnections[player .. "_team"] then
            safeDisconnect(playerConnections[player .. "_team"])
            playerConnections[player .. "_team"] = nil
        end
    end)
    activeConnections[#activeConnections + 1] = playerRemovingConn
    
    -- Tambahan buat mobile: refresh periodik (biar ESP ga hilang)
    if isMobile then
        local refreshConn = RunService.Heartbeat:Connect(function()
            if isActive then
                -- Cuma refresh setiap 2 detik, ga setiap frame
                if os.clock() % 2 < 0.03 then
                    UpdateAllHighlights()
                end
            end
        end)
        activeConnections[#activeConnections + 1] = refreshConn
    end
end

local function initialize()
    setupConnections()
    
    local playersList = Players:GetPlayers()
    for i = 1, #playersList do
        local p = playersList[i]
        if p ~= localPlayer then
            BindPlayerEvents(p)
            UpdateSinglePlayerWithRetry(p, 0)
        end
    end
    
    CheckAndToggle()
end

initialize()

-- ==========================================
-- MOONWALK MOBILE ONLY - NO KEYBOARD
-- Buat HP kentang, ga ada event keyboard nganggur
-- ==========================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local humanoid = char:WaitForChild("Humanoid")
local rootPart = char:WaitForChild("HumanoidRootPart")

local currentGui = nil
local button = nil
local moonwalk = false
local turningLeft = false
local turningRight = false

local baseYaw = 0
local currentYaw = 0
local maxTurn = 40
local turnSpeed = 850
local returnSpeed = 800

local function GetRole()
    if not LocalPlayer.Team then return "Lobby" end
    local name = LocalPlayer.Team.Name
    if name == "Killer" then return "Killer" end
    if name == "Survivors" then return "Survivor" end
    return "Lobby"
end

local function getYaw(cf)
    local _, y, _ = cf:ToEulerAnglesYXZ()
    return math.deg(y)
end

local function setYaw(cf, yaw)
    return CFrame.new(cf.Position) * CFrame.Angles(0, math.rad(yaw), 0)
end

local function enableMoonwalk()
    if GetRole() ~= "Survivor" then return end
    if not rootPart or not humanoid then return end
    moonwalk = true
    humanoid.AutoRotate = false
    baseYaw = getYaw(rootPart.CFrame)
    currentYaw = baseYaw
    if button then
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    end
end

local function disableMoonwalk()
    if not moonwalk then return end
    moonwalk = false
    if humanoid then
        humanoid.AutoRotate = true
    end
    if button then
        button.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    end
    turningLeft = false
    turningRight = false
end

local function destroyGUI()
    if currentGui then
        currentGui:Destroy()
        currentGui = nil
        button = nil
    end
end

local function createGUI()
    if GetRole() ~= "Survivor" then
        return
    end
    
    if currentGui then
        destroyGUI()
    end
    
    local gui = Instance.new("ScreenGui")
    gui.Name = "MoonwalkController"
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.Parent = CoreGui
    currentGui = gui
    
    button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 45, 0, 45)
    button.Position = UDim2.new(1, -50, 1, -110)
    button.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    button.Text = "R"
    button.TextColor3 = Color3.new(1, 1, 1)
    button.TextScaled = true
    button.BorderSizePixel = 0
    button.Parent = gui
    
    button.MouseButton1Down:Connect(enableMoonwalk)
    button.MouseButton1Up:Connect(disableMoonwalk)
    button.TouchBegan:Connect(enableMoonwalk)
    button.TouchEnded:Connect(disableMoonwalk)
end

-- Respawn karakter
LocalPlayer.CharacterAdded:Connect(function(newChar)
    char = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    rootPart = newChar:WaitForChild("HumanoidRootPart")
    if moonwalk then
        disableMoonwalk()
    end
end)

-- TOUCH CONTROL (mobile aja)
UIS.TouchMoved:Connect(function(input)
    if not moonwalk or GetRole() ~= "Survivor" then return end
    if math.abs(input.Delta.X) > 3 then
        if input.Delta.X > 0 then
            turningRight = true
            turningLeft = false
        else
            turningLeft = true
            turningRight = false
        end
    end
end)

UIS.TouchEnded:Connect(function()
    turningLeft = false
    turningRight = false
end)

-- RENDER LOOP (optimized)
RunService.RenderStepped:Connect(function(dt)
    if not moonwalk then return end
    if GetRole() ~= "Survivor" then
        if moonwalk then disableMoonwalk() end
        return
    end
    if not rootPart or not humanoid then return end
    
    if turningLeft then
        currentYaw = math.clamp(currentYaw - turnSpeed * dt, baseYaw - maxTurn, baseYaw + maxTurn)
    elseif turningRight then
        currentYaw = math.clamp(currentYaw + turnSpeed * dt, baseYaw - maxTurn, baseYaw + maxTurn)
    else
        if currentYaw < baseYaw then
            currentYaw = math.min(currentYaw + returnSpeed * dt, baseYaw)
        elseif currentYaw > baseYaw then
            currentYaw = math.max(currentYaw - returnSpeed * dt, baseYaw)
        end
    end
    
    rootPart.CFrame = setYaw(CFrame.new(rootPart.CFrame.Position), currentYaw)
end)

-- Pas ganti team
LocalPlayer:GetPropertyChangedSignal("Team"):Connect(function()
    if GetRole() == "Survivor" then
        createGUI()
    else
        destroyGUI()
        if moonwalk then
            disableMoonwalk()
        end
    end
end)

-- Start awal
createGUI()
